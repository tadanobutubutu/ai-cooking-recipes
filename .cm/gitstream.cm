# -*- mode: yaml -*-

manifest:
  version: 1.0

automations:
  handle_ai_prs:
    if:
      - {{ pr.author == 'tadanobutubutu' or pr.author == 'devin-ai-integration[bot]' or pr.author == 'google-labs-jules[bot]' }}
    run:
      - action: add-label@v1
        args:
          label: 'automerge'
      - action: change-pr-state@v1
        args:
          state: OPEN
