# -*- mode: yaml -*-

manifest:
  version: 1.0

automations:
  # AIエージェントおよびユーザーからのPRを自動的に処理
  approve_and_label_ai:
    if:
      - {{ pr.author == 'devin-ai-integration[bot]' or pr.author == 'google-labs-jules[bot]' or pr.author == 'tadanobutubutu' }}
    run:
      # ドラフト解除（gitStream Appが権限を持っていれば実行される）
      - action: approve@v1
      - action: add-label@v1
        args:
          labels: ['automerge']
